// Prisma schema for Playbeat Digital - MongoDB backend

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites     Favorite[]
  watchHistory  WatchHistory[]
}

model Favorite {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  channelId    String
  channelName  String
  channelLogo  String?
  category     String?
  streamUrl    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
}

model WatchHistory {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  channelId    String
  channelName  String
  channelLogo  String?
  category     String?
  streamUrl    String?
  watchedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
}

model AdminSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  email     String
  createdAt DateTime @default(now())
  expiresAt DateTime
}

/// Indexed channel from the IPTV M3U playlist.
/// Populated by the admin "Index Now" action.
model Channel {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  streamId   String   @unique
  name       String
  logo       String?
  category   String
  streamUrl  String
  streamFmt  String   @default("ts") // "m3u8" | "ts" | "other"
  featured   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category])
  @@index([featured])
  @@index([name])
}

/// Metadata about the last indexing run.
model IndexMeta {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique // "last_index"
  totalChannels Int    @default(0)
  totalCategories Int  @default(0)
  status      String   @default("idle") // "idle" | "running" | "success" | "error"
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Zapier webhook configuration (single row, key = "zapier")
model ZapierConfig {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique @default("zapier")
  webhookUrl  String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Log of broadcast messages sent to Zapier
model ZapierBroadcast {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  message     String
  payload     String   // JSON string of the full payload sent
  status      String   @default("pending") // "pending" | "sent" | "failed"
  response    String?  // Response from Zapier (truncated)
  sentAt      DateTime @default(now())

  @@index([sentAt])
}
